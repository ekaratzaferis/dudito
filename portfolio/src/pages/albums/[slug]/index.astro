---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import LeftPanel from '../../../components/LeftPanel.astro'
import { fetchResources, fetchAlbumAssets, extractYear } from '../../../lib/lightroom'
import selectionsRaw from '../../../../selections.json'

const selections = selectionsRaw as Record<string, { slug: string; photos: string[] }>

export async function getStaticPaths() {
  const sel = selectionsRaw as Record<string, { slug: string; photos: string[] }>
  const resources = await fetchResources()

  // Build panel album list (shared across all album pages)
  const panelAlbums = Object.entries(sel).map(([albumId, { slug }]) => {
    const resource = resources.find(r => r.id === albumId)
    return {
      slug,
      name: resource?.name ?? albumId,
      year: resource ? extractYear(resource.name) : '',
    }
  })

  const paths = []

  for (const [albumId, { slug, photos: selectedIds }] of Object.entries(sel)) {
    const resource = resources.find(r => r.id === albumId)
    const allAssets = await fetchAlbumAssets(albumId)
    const selectedPhotos = allAssets.filter(a => selectedIds.includes(a.id))

    paths.push({
      params: { slug },
      props: {
        albumId,
        albumName: resource?.name ?? albumId,
        selectedPhotos,
        panelAlbums,
      },
    })
  }

  return paths
}

const { albumName, selectedPhotos, panelAlbums } = Astro.props
const currentSlug = Astro.params.slug
---

<BaseLayout title={albumName}>
  <LeftPanel albums={panelAlbums} currentSlug={currentSlug} />

  <div class="page-layout">
    <main class="main-content">
      <header class="album-header">
        <h1 class="album-title">{albumName}</h1>
        <span class="photo-count">{selectedPhotos.length} photos</span>
      </header>

      <div class="photo-grid">
        {selectedPhotos.map(photo => (
          <a href={`/albums/${currentSlug}/${photo.id}/`} class="photo-card">
            <div class="photo-thumb">
              {photo.thumbnailUrl
                ? <img src={photo.thumbnailUrl} alt="" loading="lazy" />
                : <div class="thumb-placeholder" />
              }
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .page-layout {
    min-height: 100vh;
    background: var(--color-bg);
    padding-left: var(--panel-width);
    transition: padding-left var(--transition);
  }

  :global(body.panel-thin) .page-layout {
    padding-left: var(--panel-width-thin);
  }

  .main-content {
    padding: var(--space-5);
  }

  /* ── Header ── */

  .album-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .album-title {
    font-size: var(--font-lg);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .photo-count {
    font-size: var(--font-sm);
    color: var(--color-text-muted);
  }

  /* ── Photo Grid ── */

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-2);
  }

  .photo-card {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: border-color var(--transition);
  }

  .photo-card:hover {
    border-color: var(--color-accent);
  }

  .photo-thumb {
    width: 100%;
    height: 100%;
  }

  .photo-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .photo-card:hover .photo-thumb img {
    transform: none;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-surface-2);
  }
</style>
